# Copy this file to .env and fill in your values.
# .env is gitignored so your real token is never committed.

# Bot token from Discord Developer Portal -> your app -> Bot -> Reset Token.
# This is a SECRET. It is NOT the Application ID and NOT the Public Key.
DISCORD_TOKEN=your-bot-token-here

# Target channel ID. From a channel URL
# https://discord.com/channels/<server-id>/<channel-id> it is the second number.
DISCORD_CHANNEL_ID=your-channel-id-here
